# ============================================================
# NAP HRMS — Environment Variables (API)
# ============================================================

# Environment
NODE_ENV=development
PORT=4000

# Next.js Frontend URL (for CORS and email redirects)
FRONTEND_URL=http://localhost:3000

# ------------------------------------------------------------
# Database (Supabase PostgreSQL)
# ------------------------------------------------------------
# Connect to Supabase via connection pooling with Supavisor.
DATABASE_URL="postgres://postgres.mxyzp:[YOUR-PASSWORD]@aws-0-ap-south-1.pooler.supabase.com:6543/postgres?pgbouncer=true"

# Direct connection to the database. Used for migrations.
DIRECT_URL="postgres://postgres.mxyzp:[YOUR-PASSWORD]@aws-0-ap-south-1.pooler.supabase.com:5432/postgres"

# ------------------------------------------------------------
# Supabase Auth & Services
# ------------------------------------------------------------
SUPABASE_URL="https://mxyzp.supabase.co"
SUPABASE_SERVICE_ROLE_KEY="eyJhbGciOiJIUzI1NiIsInR5c...[YOUR-SERVICE-ROLE-KEY]"

# ------------------------------------------------------------
# Email (Resend)
# ------------------------------------------------------------
RESEND_API_KEY="re_123456789"
EMAIL_FROM="Nirvigh HR <hr@nirvighadvisors.com>"

# ------------------------------------------------------------
# Security
# ------------------------------------------------------------
# Used for encrypting sensitive fields in the DB (bank numbers, etc)
# Must be exactly 32 bytes (256 bits) for AES-256
ENCRYPTION_KEY="your-32-character-secret-key-goes-here!!"
